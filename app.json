{
  "expo": {
    "name": "ListForge",
    "slug": "ListForge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "listforge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ListForge uses the camera to guide listing photos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ListForge uses your photo library so you can upload listing photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ListForge saves exported listing images to your photo library."
        }
      ],
      [
        "rn-mlkit-ocr",
        {
          "ocrModels": [
            "latin"
          ],
          "ocrUseBundled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
